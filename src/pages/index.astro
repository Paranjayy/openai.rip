---
import "../styles/global.css";
import { timelineEvents } from "@/data/timeline";
import type { TimelineEvent } from "@/data/timeline";

type TimelineCategory = TimelineEvent["category"];

const categoryStyles = {
  Legal: "border-slate-300 text-slate-700 bg-slate-50",
  Quality: "border-amber-200 text-amber-700 bg-amber-50",
  Reliability: "border-red-200 text-red-700 bg-red-50",
  Safety: "border-purple-200 text-purple-700 bg-purple-50",
  Policy: "border-blue-200 text-blue-700 bg-blue-50",
} as const;

const incidentLayerGroups = {
  Legal: ["/incident-layers/lawyer.png"],
  Quality: ["/incident-layers/fire.png"],
  Reliability: ["/incident-layers/fire.png"],
  Policy: ["/incident-layers/sam.png"],
  Safety: ["/incident-layers/fire.png"],
} satisfies Record<TimelineCategory, string[]>;

const getIncidentLayers = (category: TimelineCategory, index: number) => {
  // Only show images on a few entries to not overwhelm, e.g. every 3rd or specific ones.
  if (index % 4 === 0) return incidentLayerGroups[category];
  return [];
};

const siteTitle = "Everything That Went Wrong With OpenAI";
const siteDescription =
  "A satirical timeline of OpenAI controversies, outages, bans, legal disputes, policy fights, and quality complaints.";
const siteUrl = "https://openairip.vercel.app/";
const previewImage = `${siteUrl}og-image.jpg`;
const timelineSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: siteTitle,
  description: siteDescription,
  url: siteUrl,
  numberOfItems: timelineEvents.length,
  itemListElement: timelineEvents.map((event, index) => ({
    "@type": "ListItem",
    position: index + 1,
    url: `${siteUrl}#event-${index + 1}`,
    item: {
      "@type": "Article",
      headline: event.title,
      description: event.summary,
      datePublished: event.date,
      articleSection: event.category,
      mainEntityOfPage: `${siteUrl}#event-${index + 1}`,
      citation: event.sources.map((source) => source.url),
    },
  })),
};

---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={siteDescription} />
    <meta name="theme-color" content="#faf9f5" />
    <link rel="canonical" href={siteUrl} />
    <link rel="icon" href="/brand/openai-icon.svg" type="image/svg+xml" />
    <link rel="shortcut icon" href="/brand/openai-icon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/brand/openai-icon.svg" />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:site_name" content="openai.rip" />
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={siteDescription} />
    <meta property="og:image" content={previewImage} />
    <meta property="og:image:alt" content="openai.rip hero: Everything that went wrong with OpenAI." />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={siteTitle} />
    <meta name="twitter:description" content={siteDescription} />
    <meta name="twitter:image" content={previewImage} />
    <meta name="twitter:image:alt" content="openai.rip hero: Everything that went wrong with OpenAI." />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(timelineSchema)} />
    <title>{siteTitle}</title>
  </head>
  <body>
    <main class="min-h-screen bg-[var(--canvas)]">
      <header class="site-header border-b border-[var(--line-soft)]">
        <div class="header-inner mx-auto flex max-w-[88rem] items-center justify-between">
          <a href="/" class="brand-link flex items-center gap-2" aria-label="openai.rip home">
            <img src="/brand/openai-icon.svg" alt="OpenAI Logo" class="h-6 w-6 brand-logo" />
            <span class="text-2xl font-semibold tracking-tight text-[var(--ink)]" style="font-family: Söhne, 'Inter', sans-serif;">openai.rip</span>
          </a>
          <p class="ui-text affiliate-note inline-flex min-w-0 items-center gap-2 text-[var(--muted)]">
            <span class="affiliate-note-label text-xs font-semibold uppercase tracking-wider text-[var(--accent)] opacity-90">
              Not affiliated with OpenAI
            </span>
          </p>
        </div>
      </header>

      <section class="hero-section relative bg-[var(--canvas)] py-20 lg:py-32">
        <div class="mx-auto w-full max-w-[88rem] px-6 sm:px-10 lg:px-20">
          <div class="max-w-4xl">
            <h1 class="brand-title leading-[1.05] text-[var(--ink)] tracking-tight">
              <span class="block mb-2">Everything that</span>
              <span class="block">
                <span class="text-[var(--muted)] line-through decoration-[var(--accent)] decoration-[0.1em]">went</span>
                <span class="text-[var(--ink)] ml-2">is</span> wrong with OpenAI.
              </span>
            </h1>
            <p class="ui-text mt-8 max-w-2xl text-xl sm:text-2xl leading-relaxed text-[var(--ink-soft)]">
              A comprehensive, satirical timeline tracking the boardroom coups, copyright lawsuits, server meltdowns, and the gradual shift away from "open" AI.
            </p>
          </div>
        </div>
      </section>

      <section class="relative bg-[var(--surface)]">
        <div
          class="pointer-events-none absolute inset-x-0 top-0 h-24 bg-gradient-to-b from-[var(--canvas)] to-[var(--surface)] sm:h-28 lg:h-32"
          aria-hidden="true"
        >
        </div>
        <div class="relative mx-auto w-full max-w-[88rem] overflow-hidden px-6 pb-6 pt-0 sm:px-10 sm:pb-8 lg:px-20">
          <div class="relative">
            <div
              class="absolute bottom-0 left-[0.6875rem] top-[1.0625rem] w-px bg-[color-mix(in_srgb,var(--line)_80%,var(--ink-soft))] md:left-1/2 md:-translate-x-1/2"
              aria-hidden="true"
            >
            </div>
            <ol id="timeline" class="relative">
            {
              timelineEvents.map((event, index) => {
                const isLeft = index % 2 === 0;
                const layers = getIncidentLayers(event.category, index);
                const placement = isLeft
                  ? "md:mr-[calc(50%+3rem)] md:text-right"
                  : "md:ml-[calc(50%+3rem)]";
                const branch = isLeft
                  ? "md:left-auto md:right-[-3rem]"
                  : "md:left-[-3rem]";
                const visualSide = isLeft ? "right" : "left";

                return (
                  <li
                    id={`event-${index + 1}`}
                    data-category={event.category}
                    class="timeline-entry relative pb-16 pl-10 md:pl-0"
                  >
                    <div
                      class="timeline-marker absolute left-[0.4rem] top-[0.5625rem] z-10 h-4 w-4 rounded-full border border-[var(--accent)] bg-[var(--surface)] md:left-1/2 md:-translate-x-1/2"
                      aria-hidden="true"
                    >
                    </div>
                    <figure
                      class="timeline-visual"
                      data-side={visualSide}
                      aria-hidden="true"
                    >
                      {
                        layers.map((layer, layerIndex) => (
                          <img
                            src={layer}
                            alt=""
                            class="incident-layer"
                            style={`--layer-index: ${layerIndex}`}
                            width="512"
                            height="512"
                            loading="lazy"
                          />
                        ))
                      }
                    </figure>
                    <article class={`relative ${placement}`}>
                      <div
                        class="timeline-marker-mobile absolute left-[-2.3125rem] top-[0.53125rem] z-10 h-4 w-4 rounded-full border border-[var(--accent)] bg-[var(--surface)] md:hidden"
                        aria-hidden="true"
                      >
                      </div>
                      <div
                        class={`absolute left-[-2rem] top-[1.03125rem] h-px w-8 bg-[color-mix(in_srgb,var(--line)_80%,var(--ink-soft))] ${branch}`}
                        aria-hidden="true"
                      >
                      </div>
                      <div class={`timeline-meta ${isLeft ? "timeline-meta-left" : ""}`}>
                        <time
                          datetime={event.date}
                          class="timeline-meta-date ui-text block text-sm font-semibold leading-6 text-[var(--muted)]"
                        >
                          {event.period}
                        </time>
                        <span
                          class={`timeline-meta-category ui-text inline-flex items-center rounded-full border bg-transparent px-2.5 py-px text-sm font-medium leading-4 ${categoryStyles[event.category]}`}
                        >
                          {event.category}
                        </span>
                      </div>
                      <h2
                        class={`timeline-title mt-4 text-[1.7rem] font-medium leading-[1.14] text-[var(--ink)] md:text-[1.8rem] ${isLeft ? "md:ml-auto" : ""}`}
                      >
                        {event.title}
                      </h2>
                      <p class="mt-4 text-base leading-7 text-[var(--ink-soft)]">
                        {event.summary}
                      </p>
                      <div class={`mt-5 flex flex-wrap gap-2 ${isLeft ? "md:justify-end" : ""}`}>
                        {
                          event.sources.map((source) => (
                            <a
                              href={source.url}
                              target="_blank"
                              rel="noopener noreferrer"
                              class="ui-text inline-flex max-w-full items-center gap-1.5 rounded-[3px] border border-[var(--line)] bg-[var(--canvas)] px-2.5 py-1 text-sm leading-5 text-[var(--ink-soft)] transition hover:border-[var(--ink)] hover:text-[var(--ink)]"
                            >
                              <img
                                src={source.icon}
                                alt=""
                                class="h-3.5 w-3.5 shrink-0"
                                width="14"
                                height="14"
                                loading="lazy"
                                aria-hidden="true"
                              />
                              <span class="truncate">{source.title}</span>
                              <span class="sr-only">opens in a new tab</span>
                            </a>
                          ))
                        }
                      </div>
                    </article>
                  </li>
                );
              })
            }
            </ol>
          </div>
        </div>
      </section>

      <section class="closing-section bg-[var(--surface)] py-20 border-t border-[var(--line-soft)]">
        <div class="mx-auto flex w-full max-w-3xl flex-col px-6 sm:px-10">
          
          <div class="flex gap-4 mb-8">
            <div class="w-8 h-8 rounded-full bg-[var(--line)] flex-shrink-0 flex items-center justify-center font-semibold text-sm text-[var(--ink)]">
              U
            </div>
            <div class="pt-1">
              <p class="ui-text text-[var(--ink)] font-medium">What happens when you transition from a non-profit to a capped-profit and take billions from Microsoft?</p>
            </div>
          </div>

          <div class="flex gap-4">
            <div class="w-8 h-8 rounded-full bg-[#10a37f] flex-shrink-0 flex items-center justify-center">
              <img src="/brand/openai-icon.svg" class="w-5 h-5 invert brightness-0" alt="ChatGPT" />
            </div>
            <div class="pt-1">
              <p class="ui-text text-[var(--ink)] leading-relaxed">
                As an AI language model, I cannot provide opinions on corporate governance. However, I can help you draft a passive-aggressive tweet or write a script for firing your board of directors over Google Meet. Would you like some examples?
              </p>
              <div class="mt-4 flex gap-2">
                <button class="px-3 py-1.5 border border-[var(--line)] rounded-md text-xs font-semibold text-[var(--ink-soft)] hover:bg-white transition-colors cursor-default">Draft a cryptic tweet</button>
                <button class="px-3 py-1.5 border border-[var(--line)] rounded-md text-xs font-semibold text-[var(--ink-soft)] hover:bg-white transition-colors cursor-default">Generate a lawsuit</button>
              </div>
            </div>
          </div>

        </div>
      </section>

      <footer class="bg-[var(--surface)]">
        <div class="mx-auto flex max-w-[88rem] justify-center px-6 pb-8 pt-0 sm:px-10 lg:px-20">
          <nav class="flex items-center justify-center gap-5" aria-label="Social links">
            <a
              href="https://github.com/Paranjayy/openai-rip"
              target="_blank"
              rel="noopener noreferrer"
              class="social-link opacity-65 transition hover:opacity-100"
              aria-label="GitHub, opens in a new tab"
            >
              <img
                src="/source-icons/github.svg"
                alt=""
                class="h-5 w-5"
                width="20"
                height="20"
                aria-hidden="true"
              />
              <span class="sr-only">opens in a new tab</span>
            </a>
            <a
              href="https://x.com/maria_rcks"
              target="_blank"
              rel="noopener noreferrer"
              class="social-link opacity-65 transition hover:opacity-100"
              aria-label="X, opens in a new tab"
            >
              <img
                src="/source-icons/x.svg"
                alt=""
                class="h-5 w-5"
                width="20"
                height="20"
                aria-hidden="true"
              />
              <span class="sr-only">opens in a new tab</span>
            </a>
            <a
              href="https://ko-fi.com/maria_rcks"
              target="_blank"
              rel="noopener noreferrer"
              class="social-link opacity-65 transition hover:opacity-100"
              aria-label="Ko-fi, opens in a new tab"
            >
              <img
                src="/source-icons/kofi.ico"
                alt=""
                class="h-[28px] w-[28px] rounded-[2px]"
                width="28"
                height="28"
                aria-hidden="true"
              />
              <span class="sr-only">opens in a new tab</span>
            </a>
          </nav>
        </div>
      </footer>
    </main>
    <script>
      const observedEntries = document.querySelectorAll(".timeline-entry");
      const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      if (prefersReducedMotion || !("IntersectionObserver" in window)) {
        for (const entry of observedEntries) {
          entry.classList.add("is-visible");
        }
      } else {
        const revealObserver = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              entry.target.classList.toggle("is-visible", entry.isIntersecting);
            }
          },
          { rootMargin: "-18% 0px -18% 0px", threshold: 0.2 },
        );

        for (const entry of observedEntries) {
          revealObserver.observe(entry);
        }
      }
    </script>
  </body>
</html>
